# Environment (optional, defaults to NODE_ENV)
SENTRY_ENVIRONMENT=

# Sampling rates for performance monitoring
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=

# Enable/disable Sentry
SENTRY_ENABLED=
