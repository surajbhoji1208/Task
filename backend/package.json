{
    "name": "node-backend-v3",
    "version": "0.0.1",
    "description": "",
    "author": "Kishan Gajipara",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "NODE_ENV=development npm run prebuild && nest build && npm run migration:run",
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "NODE_ENV=development nest start",
        "start:dev": "NODE_ENV=development nest start --watch",
        "start:debug": "NODE_ENV=development nest start --debug --watch",
        "start:prod": "NODE_ENV=production node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "prepare": "husky install .husky",
        "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js --dataSource libs/@oc/server-core/database/data-source.ts",
        "migration:create:db-changes": "NODE_ENV=development npm run typeorm -- migration:create libs/@oc/server-core/database/migrations/database-changes/$npm_config_name",
        "migration:create:functions": "NODE_ENV=development npm run typeorm -- migration:create libs/@oc/server-core/database/migrations/functions/$npm_config_name",
        "migration:create:seeds": "NODE_ENV=development npm run typeorm -- migration:create libs/@oc/server-core/database/migrations/seeds/$npm_config_name",
        "migration:generate": "NODE_ENV=development npm run typeorm -- migration:generate libs/@oc/server-core/database/migrations/$npm_config_name",
        "migration:run": "NODE_ENV=development npm run typeorm -- migration:run",
        "migration:revert": "NODE_ENV=development npm run typeorm -- migration:revert",
        "migration:show": "NODE_ENV=development npm run typeorm -- migration:show",
        "compodoc": "npx @compodoc/compodoc -p tsconfig.json -s"
    },
    "dependencies": {
        "@nestjs-modules/mailer": "^2.0.2",
        "@nestjs/cache-manager": "^3.1.0",
        "@nestjs/common": "^11.1.11",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.1.11",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.11",
        "@nestjs/schedule": "^6.1.0",
        "@nestjs/swagger": "^11.2.3",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/typeorm": "^11.0.0",
        "@sentry/nestjs": "^10.32.1",
        "@sentry/node": "^10.32.1",
        "@sentry/profiling-node": "^10.32.1",
        "@types/cache-manager": "^5.0.0",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "compression": "^1.8.1",
        "config": "^4.1.1",
        "cookie-parser": "^1.4.7",
        "csv-parse": "^6.1.0",
        "dotenv": "^17.2.3",
        "helmet": "^8.1.0",
        "html-pdf-node": "^1.0.8",
        "joi": "^18.0.2",
        "multer": "^2.1.1",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "rimraf": "^6.1.2",
        "rxjs": "^7.8.2",
        "typeorm": "^0.3.28",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@compodoc/compodoc": "^1.1.32",
        "@nestjs/cli": "^11.0.14",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.11",
        "@types/bcrypt": "^6.0.0",
        "@types/config": "^3.3.5",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.0.3",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^8.52.0",
        "@typescript-eslint/parser": "^8.52.0",
        "depcheck": "^1.4.7",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.4",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.7.4",
        "pretty-quick": "^4.2.2",
        "source-map-support": "^0.5.21",
        "supertest": "^7.1.4",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "webpack": "^5.104.1"
    },
    "husky": {
        "hooks": {
            "pre-commit": "npx pretty-quick --staged && npm run lint"
        }
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
